</section>


<section class="registry-features-section">
    <div class="registry-features-container">
        <h2>Make your registry unique to you</h2>
        
        <div class="registry-features-grid">
            

            <div class="feature-card">
                <div class="feature-image">
                    <img src="assets/images/Registry/r-17.png" alt="Camera, Kindle, and travel books">
                </div>
                <div class="feature-content">
                    <h3>Building made easy</h3>
                    <p>Use our recommendations or add items from product pages.</p>
                </div>
            </div>


            <div class="feature-card">
                <div class="feature-image">
                    <img src="assets/images/Registry/r-18.png" alt="Gift bags and home decor">
                </div>
                <div class="feature-content">
                    <h3>Keep track of everything</h3>
                    <p>We help keep track of who bought what item and when, so it's easy for you to send thank you notes and manage purchases.</p>
                </div>
            </div>


            <div class="feature-card">
                <div class="feature-image">
                    <img src="assets/images/Registry/r-19.png" alt="Instant cameras and photo prints">
                </div>
                <div class="feature-content">
                    <h3>Personalize your registry</h3>
                    <p>Add notes and highlight your most wanted gifts to guests.</p>
                </div>
            </div>


            <div class="feature-card">
                <div class="feature-image">
                    <img src="assets/images/Registry/r-20.jpg" alt="Coffee maker and mugs">
                </div>
                <div class="feature-content">
                    <h3>Easy to shop</h3>
                    <p>Shopping an Amazon Registry is a familiar experience for family and friends.</p>
                </div>
            </div>

        </div>
    </div>
