<body>

<jsp:include page="nav.jsp" />


	<section class="registry-section">
    <!-- Sub Navigation -->
    <div class="registry-subnav">
        <span class="subnav-title">registry & gifting</span>
        <a href="account">Find a registry or gift list</a>
        <a href="account">Create a registry or gift list</a>
        <a href="#">Help</a>
    </div>

    <!-- Cards Grid -->
    <div class="registry-grid">

        <div class="registry-card card-intro">
            <h2>Inspiration for life's<br>biggest moments</h2>
            <p>
                For weddings, babies, birthdays, or any life event, registries and 
                gift lists ensure the perfect item.
            </p>
            <div class="card-actions">
                <a href="account" class="btn-outline">Find a registry</a>
                <a href="account" class="btn-solid">Create</a>
            </div>
        </div>


        <a href="account" class="registry-card">
            <div class="card-image">
                <img src="assets/images/Registry/r-1.jpeg" alt="Baby items including shoes and toys">
            </div>
            <div class="card-body">
                <h3>Baby Registry</h3>
                <p>Get help preparing for your new arrival.</p>
            </div>
        </a>


        <a href="account" class="registry-card">
            <div class="card-image">
                <img src="assets/images/Registry/r-2.jpg" alt="Wedding table setting with wine glasses">
            </div>
            <div class="card-body">
                <h3>Wedding Registry</h3>
                <p>Register for gifts to start your new chapter.</p>
            </div>
        </a>


        <a href="account" class="registry-card">
            <div class="card-image">
                <img src="assets/images/Registry/r-3.jpeg" alt="Wrapped gifts with gold bows">
            </div>
            <div class="card-body">
                <h3>Gift List</h3>
                <p>Share gift ideas or needs for birthdays, holidays, graduations, new homes and more.</p>
            </div>
        </a>

    </div>
</section>


<section class="reasons-section">
    <div class="reasons-container">
        <h2>Reasons to register with Amazon</h2>
        
        <div class="reasons-grid">
            

            <div class="reason-card">
                <div class="reason-icon">
                    <img alt="" src="assets/images/Registry/r-4.png">
                </div>
                <h3>Earth's biggest selection</h3>
                <p>Add items from Amazon to create a gift registry for any occasion.</p>
            </div>


            <div class="reason-card">
                <div class="reason-icon">
                    <img alt="" src="assets/images/Registry/r-5.png">
                </div>
                <h3>Easy to share</h3>
                <p>Share your gift registry with friends and family so they'll know exactly what gifts to get.</p>
            </div>


            <div class="reason-card">
                <div class="reason-icon">
                    <img alt="" src="assets/images/Registry/r-6.png">
                </div>
                <h3>Extended returns</h3>
                <p>Not quite right? Registry gifts have an extended return period.</p>
            </div>

        </div>
    </div>
</section>

