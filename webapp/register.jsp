                </div>
                <div class="type-label">College</div>
            </a>

			<a href="account" class="registry-type-card">
                <div class="type-image">
                    <img src="assets/images/Registry/r-13.jfif" alt="Headphones and flat iron">
                </div>
                <div class="type-label">College</div>
            </a>
            
            <a href="account" class="registry-type-card">
                <div class="type-image">
                    <img src="assets/images/Registry/r-14.jpg" alt="Headphones and flat iron">
                </div>
                <div class="type-label">College</div>
            </a>
            
            <a href="account" class="registry-type-card">
                <div class="type-image">
                    <img src="assets/images/Registry/r-15.jpg" alt="Headphones and flat iron">
                </div>
                <div class="type-label">College</div>
            </a>
            
            <a href="account" class="registry-type-card">
